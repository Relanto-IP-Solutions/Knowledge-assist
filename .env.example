# Backend base URL (no trailing slash). When unset, most call sites default to http://localhost:8000;
# opportunities list + OAuth URL helpers default to http://localhost:8080 — set this once so all APIs match.
VITE_API_BASE=http://localhost:8000

# Firebase Auth — Email/Password, Google (popup), and Microsoft / Azure AD (custom OIDC `oidc.azure-ad`).
# Project settings → Your apps → SDK setup
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# Add your SPA origin under Authentication → Settings → Authorized domains (e.g. localhost).
# Optional: allowed email domain (default relanto.ai)
# VITE_AUTH_EMAIL_DOMAIN=relanto.ai

# Set to true to load Q&A + landing coverage from GET /opportunities/{id}/answers (restart dev server after change).
# Use plain true on one line; avoid trailing spaces (Windows CRLF is OK — the app trims the value).
VITE_USE_OPPORTUNITY_ANSWERS_API=false

# Optional demo only: when the API omits `conflicts[]`, merge conflicts from src/data/oid0009ConflictOverrides.json.
# Default is off — only GET /answers rows that include conflicts[] / conflict_id show conflict UI. Set "true" to enable stub.
# VITE_STUB_ANSWER_CONFLICTS=true

# When GET /answers omits `citations[]`, merge stub citations (oid0009 demo data). Unset or true = merge; set "false" to disable.
# VITE_STUB_ANSWER_CITATIONS=false

# Optional: map UI opportunity id -> API opportunity id (JSON object)
# VITE_OPPORTUNITY_ID_MAP={"OID/112299":"backend_opp_id"}

# OAuth redirect URI must match the provider console exactly (trailing slash, no query). Default: `{origin}/`.
# VITE_OAUTH_REDIRECT_URI=http://localhost:5173/

# Targeted Gmail: frontend URL passed as `redirect_uri` to POST /integrations/gmail/discover and /connect (user returns here after OAuth). Default: `{origin}/gmail-result`.
# VITE_GMAIL_FRONTEND_REDIRECT_URI=http://localhost:5173/gmail-result
# Optional override for `return_url` in those payloads (defaults to same as frontend redirect when unset).
# VITE_GMAIL_RETURN_URL=http://localhost:5173/gmail-result
# Backend Gmail OAuth callback registered in Google Cloud (default: `{VITE_API_BASE}/integrations/gmail/callback`).
# VITE_GMAIL_REDIRECT_URI=http://localhost:8000/integrations/gmail/callback

# Zoom: `days_lookback` query param for POST /zoom/discover (default 14 per API guide).
# VITE_ZOOM_DAYS_LOOKBACK=30

# Dev only: log Firebase ID token (JWT) after sign-in and on each Axios request.
# Accepts true / 1 / yes. Never enable in production. Restart dev server after changing.
# VITE_DEBUG_LOG_JWT=true

# Optional: Bearer token for authenticated APIs
# VITE_API_BEARER_TOKEN=

# Optional: Vite dev server port (default 5173). Used by vite.config.js only, not exposed to the browser.
# PORT=5173
