# =============================================================================
# NON-SECRET CONFIGURATION (EXAMPLE)
# =============================================================================
# Copy this file to .env and fill with your values.
# Secrets (credentials, passwords) go in configs/secrets/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment: development | staging | production | test
APP_ENV=development

# Browser CORS: * allows any origin (then credentials=false per CORS). For cookie/auth
# headers from a specific SPA, set comma-separated origins, e.g.:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://0.0.0.0:5173
CORS_ALLOW_ORIGINS=*

# -----------------------------------------------------------------------------
# GCP Project & Storage
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_INGESTION=your-project-ingestion-bucket

# -----------------------------------------------------------------------------
# Vertex AI / LLM
# -----------------------------------------------------------------------------
VERTEX_AI_LOCATION=us-central1
LLM_MODEL_NAME=gemini-2.5-flash

# -----------------------------------------------------------------------------
# PostgreSQL / Cloud SQL
# -----------------------------------------------------------------------------
# For local dev: set PG_HOST=0.0.0.0 (requires Cloud SQL Auth Proxy or local PG)
# For Cloud Run: leave PG_HOST empty to use Cloud SQL connector with instance name
PG_HOST=0.0.0.0
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_SSLMODE=disable
CLOUDSQL_USE_IAM_AUTH=false

# Optional: SSL root certificate path (for secure connections)
# PG_SSLROOTCERT=/path/to/server-ca.pem

# Optional: Connection pool sizing (defaults: min=1, max=10)
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIRECTORY=logs
LOG_NAME=app.log
LOG_MAX_BYTES=1000000000
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Pub/Sub Topics & Subscriptions
# -----------------------------------------------------------------------------
PUBSUB_TOPIC_RAG_INGESTION=rag-ingestion-queue
PUBSUB_SUBSCRIPTION_RETRIEVAL_INITIATION=rag-retrieval-initiation-sub

# -----------------------------------------------------------------------------
# RAG Retrieval Settings
# -----------------------------------------------------------------------------
K_PER_SOURCE=5
K_FINAL=3
RANK_LOCATION=global
RANKING_CONFIG_ID=default_ranking_config
RANK_MODEL=semantic-ranker-512@latest
RETRIEVAL_BATCH_SIZE=5
SIMILARITY_MIN_THRESHOLD=0

# -----------------------------------------------------------------------------
# Agent Settings (Opportunities Agent)
# -----------------------------------------------------------------------------
AGENT_MAX_RECALL_ROUNDS=2
AGENT_LOW_CONFIDENCE_THRESHOLD=0.5
AGENT_FORM_ID_PREFIX=SASE_FORM
AGENT_USE_CACHE=true

# -----------------------------------------------------------------------------
# Ingestion Pipeline (Vector Search Index Resources)
# -----------------------------------------------------------------------------
# These are the INDEX resources (not IndexEndpoints) for upserting datapoints.
# Format: projects/{PROJECT}/locations/{LOCATION}/indexes/{INDEX_ID}
#
# Option 1: Combined index for all source types (recommended)
# INDEX_RESOURCE_NAME_COMBINED=projects/{PROJECT}/locations/us-central1/indexes/{INDEX_ID}
#
# Option 2: Separate indexes per source type
# INDEX_RESOURCE_NAME_DOCUMENTS=projects/{PROJECT}/locations/us-central1/indexes/{INDEX_ID}
# INDEX_RESOURCE_NAME_SLACK=projects/{PROJECT}/locations/us-central1/indexes/{INDEX_ID}
# INDEX_RESOURCE_NAME_ZOOM=projects/{PROJECT}/locations/us-central1/indexes/{INDEX_ID}
# INDEX_RESOURCE_NAME_GMAIL=projects/{PROJECT}/locations/us-central1/indexes/{INDEX_ID}

# Optional: Deployed index IDs (if different from default)
# DEPLOYED_INDEX_ID_COMBINED=
# DEPLOYED_INDEX_ID_DOCUMENTS=
# DEPLOYED_INDEX_ID_SLACK=
# DEPLOYED_INDEX_ID_ZOOM=

# -----------------------------------------------------------------------------
# Document Extraction (Optional - defaults to Gemini-based extraction)
# -----------------------------------------------------------------------------
# Only needed if using Document AI instead of Gemini for extraction
# DOCUMENT_AI_PROCESSOR_NAME=projects/{PROJECT}/locations/{LOCATION}/processors/{PROCESSOR_ID}
# DOCUMENT_AI_CREDENTIALS_PATH=./configs/secrets/document-ai-key.json

# Gemini extraction tuning (defaults: batch_size=15, max_workers=10)
# GEMINI_EXTRACTION_BATCH_SIZE=15
# GEMINI_EXTRACTION_MAX_WORKERS=10

# -----------------------------------------------------------------------------
# Multi-connector discovery (optional)
# -----------------------------------------------------------------------------
# DRIVE_ROOT_FOLDER_NAME=Requirements
# DRIVE_SUPPORTS_ALL_DRIVES=true
# DRIVE_CONNECTOR_USER_EMAIL=connector@company.com
# SLACK_CONNECTOR_USER_EMAIL=connector@company.com
# GMAIL_CONNECTOR_USER_EMAIL=connector@company.com
# GMAIL_DISCOVER_QUERY=subject:oid
# GMAIL_DISCOVER_MAX_THREADS=200
