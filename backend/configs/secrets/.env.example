# =============================================================================
# SECRETS (EXAMPLE) - DO NOT COMMIT REAL VALUES
# =============================================================================
# Copy this file to .env and fill with real values.
# Ensure configs/secrets/.env is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Service Account
# -----------------------------------------------------------------------------
# Path to service account JSON key (relative to project root or absolute).
# Required roles: Storage Admin, Vertex AI User, Cloud SQL Client
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=./configs/secrets/gcp-service-account-key.json

# -----------------------------------------------------------------------------
# Firebase Admin (verify ID tokens from the SPA: Authorization: Bearer <JWT>)
# -----------------------------------------------------------------------------
# Option A — service account JSON (full Admin SDK; can create users, etc.):
# Download: Firebase Console → Project settings → Service accounts → Generate new private key.
# Save JSON under configs/secrets/ (gitignored). Do not commit the key file.
# FIREBASE_SERVICE_ACCOUNT_PATH=./configs/secrets/firebase-adminsdk.json
#
# Option B — no key file (e.g. org blocks creating keys): set only the Firebase project ID.
# Tokens are verified with Google's public x509 keys (signature + iss + aud + exp).
# FIREBASE_PROJECT_ID=eighth-bivouac-490806-s2
#
# Optional: comma-separated emails; empty = no extra email gate (still requires a users row).
# AUTH_EMAIL_ALLOWLIST=you@company.com,colleague@company.com

# -----------------------------------------------------------------------------
# PostgreSQL / Cloud SQL
# -----------------------------------------------------------------------------
# Password required when CLOUDSQL_USE_IAM_AUTH=false in configs/.env
PG_PASSWORD=your-secure-password

# Cloud SQL instance connection name: <project>:<region>:<instance>
# Used by Cloud SQL Python Connector when PG_HOST is empty
# Find at: https://console.cloud.google.com/sql/instances
CLOUDSQL_INSTANCE_CONNECTION_NAME=your-project:us-central1:your-instance

# -----------------------------------------------------------------------------
# OAuth Credentials - Google (Gmail, Drive)
# -----------------------------------------------------------------------------
# Google OAuth (Web Client) - for Gmail and Drive access
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: gmail.readonly, drive.readonly, userinfo.email, userinfo.profile
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Same Google account as your Drive ``Requirements`` folder and Gmail tests (must match users row with google_refresh_token).
# DRIVE_CONNECTOR_USER_EMAIL=user@gmail.com
# GMAIL_CONNECTOR_USER_EMAIL=user@gmail.com
# Gmail discover search (default ``oid`` matches subjects like "Progress Update - oid1111"; ``subject:oid`` often misses those).
# GMAIL_DISCOVER_QUERY=oid

# -----------------------------------------------------------------------------
# OAuth Credentials - Slack (optional)
# -----------------------------------------------------------------------------
# Slack OAuth App credentials (only if using Slack connector)
# Create at: https://api.slack.com/apps
# Required scopes: channels:history, channels:read, users:read
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret

# -----------------------------------------------------------------------------
# OAuth Credentials - Zoom Server-to-Server (optional)
# -----------------------------------------------------------------------------
# Zoom S2S OAuth credentials (only if using Zoom connector)
# Create at: https://marketplace.zoom.us/develop/create (Server-to-Server OAuth app)
# Required Zoom Marketplace scopes (Server-to-Server app → Scopes), e.g.:
#   cloud_recording:read:list_user_recordings
#   user:read:user (or user:read) as needed for /users/{id}/recordings
# Without list_user_recordings, Zoom returns 400 "does not contain scopes:[...list_user_recordings...]".
# These serve as fallback when user doesn't have their own Zoom credentials stored
#
# Option A — paste values here (local dev):
# ZOOM_ACCOUNT_ID=your-zoom-account-id
# ZOOM_CLIENT_ID=your-zoom-client-id
# ZOOM_CLIENT_SECRET=your-zoom-client-secret
# ZOOM_WEBHOOK_SECRET_TOKEN=your-webhook-secret
#
# Email of the Zoom *host* account whose cloud recordings you list (must match meetings in Zoom UI).
# Server-to-Server OAuth uses GET /users/{email}/recordings — set this to that login email.
# ZOOM_CONNECTOR_USER_EMAIL=you@company.com
#
# Option B — load from Google Secret Manager (GCP secrets named ZOOM_ACCOUNT_ID, etc.):
# ZOOM_SECRETS_FROM_SECRET_MANAGER=1
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./configs/secrets/gcp-service-account-key.json
# (Service account needs roles/secretmanager.secretAccessor on those secrets.)
#
# Option C — Cloud Run: use --set-secrets so the platform injects env vars, e.g.
#   ZOOM_ACCOUNT_ID=ZOOM_ACCOUNT_ID:latest,ZOOM_CLIENT_ID=ZOOM_CLIENT_ID:latest,...
# No ZOOM_SECRETS_FROM_SECRET_MANAGER needed; values are already in the environment.

# -----------------------------------------------------------------------------
# Vector Search (Vertex AI Vector Search - for RETRIEVAL)
# -----------------------------------------------------------------------------
# These are IndexEndpoints used for querying/retrieval (not upsert).
# Create at: https://console.cloud.google.com/vertex-ai/matching-engine/index-endpoints
#
# Format for public_domain: https://{ENDPOINT_NUMBER}.{LOCATION}-{PROJECT_NUMBER}.vdb.vertexai.goog
# Format for index_endpoint: projects/{PROJECT}/locations/{LOCATION}/indexEndpoints/{ENDPOINT_ID}

# Combined index (recommended - single index for all source types)
VECTOR_SOURCE_COMBINED_PUBLIC_DOMAIN=https://123456789.us-central1-123456789012.vdb.vertexai.goog
VECTOR_SOURCE_COMBINED_INDEX_ENDPOINT=projects/123456789012/locations/us-central1/indexEndpoints/1234567890123456789
VECTOR_SOURCE_COMBINED_DEPLOYED_INDEX_ID=your_deployed_index_id

# Separate indexes per source type (optional - use if not using combined)
# VECTOR_SOURCE_DRIVE_PUBLIC_DOMAIN=
# VECTOR_SOURCE_DRIVE_INDEX_ENDPOINT=
# VECTOR_SOURCE_DRIVE_DEPLOYED_INDEX_ID=

# VECTOR_SOURCE_ZOOM_PUBLIC_DOMAIN=
# VECTOR_SOURCE_ZOOM_INDEX_ENDPOINT=
# VECTOR_SOURCE_ZOOM_DEPLOYED_INDEX_ID=

# VECTOR_SOURCE_SLACK_PUBLIC_DOMAIN=
# VECTOR_SOURCE_SLACK_INDEX_ENDPOINT=
# VECTOR_SOURCE_SLACK_DEPLOYED_INDEX_ID=

# -----------------------------------------------------------------------------
# Cloud Run Service URLs (Inter-service Communication)
# -----------------------------------------------------------------------------
# URL for answer-generation service (called by rag-orchestrator)
# Deploy answer-generation Cloud Run service first, then add URL here
ANSWER_GENERATION_URL=https://answer-generation-xxxxx.run.app

# URL for pubsub-dispatch service (called by gcs_file_processor for orphan deletes)
# Deploy pubsub-dispatch Cloud Run service first, then add URL here
# PUBSUB_DISPATCH_URL=https://pubsub-dispatch-xxxxx.run.app
